page {
  background: #eeece7;
  color: #212121;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  border-radius: 999rpx;
  font-size: 28rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 36rpx 28rpx 60rpx;
}

.hero-title {
  color: #17171c;
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.08;
}

.hero-subtitle {
  color: #75758a;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 12rpx;
}

.primary-button {
  align-items: center;
  background: #17171c;
  color: #ffffff;
  display: flex;
  font-weight: 600;
  justify-content: center;
  margin: 28rpx 0;
  min-height: 92rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #d9d9dd;
  border-radius: 16rpx;
  padding: 28rpx;
}

.muted {
  color: #75758a;
  font-size: 26rpx;
}

.input,
.textarea {
  background: #ffffff;
  border: 1rpx solid #d9d9dd;
  border-radius: 12rpx;
  color: #212121;
  font-size: 28rpx;
  padding: 22rpx;
  width: 100%;
}

.textarea {
  min-height: 180rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  background: #f2f2f2;
  border-radius: 999rpx;
  color: #75758a;
  font-size: 26rpx;
  padding: 16rpx 28rpx;
}

.chip.active {
  background: #17171c;
  color: #ffffff;
}

.danger-text {
  color: #b30000;
}
