.form-section {
  margin-top: 32rpx;
}

.label {
  color: #212121;
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.picker-row {
  display: grid;
  gap: 18rpx;
  grid-template-columns: 1fr 1fr;
}

.picker-box {
  background: #ffffff;
  border: 1rpx solid #d9d9dd;
  border-radius: 12rpx;
  color: #212121;
  font-size: 28rpx;
  padding: 22rpx;
}
