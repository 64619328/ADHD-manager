<view class="page detail-page">
  <view wx:if="{{loading}}" class="panel muted">加载中...</view>

  <block wx:else>
    <view class="title-row">
      <view>
        <view class="hero-title detail-title">{{task.goal}}</view>
        <view class="hero-subtitle">任务 #{{task.id}} · 更新于 {{task.updatedText}}</view>
      </view>
      <text class="priority-label">{{task.priority}}</text>
    </view>

    <view class="section panel">
      <text class="label">任务目标</text>
      <textarea class="textarea" value="{{goalDraft}}" bindinput="onGoalInput" />
      <button class="secondary-button" loading="{{saving}}" bindtap="saveGoal">保存目标</button>
    </view>

    <view class="section panel">
      <text class="label">状态</text>
      <view class="chip-row">
        <view wx:for="{{statuses}}" wx:key="*this" class="chip {{task.status === item ? 'active' : ''}}" data-value="{{item}}" bindtap="changeStatus">{{item}}</view>
      </view>

      <text class="label spaced">优先级</text>
      <view class="chip-row">
        <view wx:for="{{priorities}}" wx:key="*this" class="chip {{task.priority === item ? 'active' : ''}}" data-value="{{item}}" bindtap="changePriority">{{item}}</view>
      </view>

      <text class="label spaced">DDL 时间</text>
      <view class="picker-row">
        <picker mode="date" value="{{deadlineDate}}" bindchange="onDateChange">
          <view class="picker-box">{{deadlineDate || "选择日期"}}</view>
        </picker>
        <picker mode="time" value="{{deadlineTime}}" bindchange="onTimeChange">
          <view class="picker-box">{{deadlineTime || "选择时间"}}</view>
        </picker>
      </view>
      <button class="secondary-button" loading="{{saving}}" bindtap="saveDeadline">保存 DDL</button>
    </view>

    <view class="section panel">
      <view class="section-head">
        <text class="label">待办项</text>
        <text class="muted">{{todoCompleted}}/{{task.todos.length}}</text>
      </view>

      <view wx:if="{{task.todos.length === 0}}" class="muted">暂无待办项</view>
      <view wx:for="{{task.todos}}" wx:key="id" class="todo-row">
        <view class="check {{item.completed ? 'checked' : ''}}" data-id="{{item.id}}" data-completed="{{item.completed}}" bindtap="toggleTodo">{{item.completed ? "✓" : ""}}</view>
        <text class="todo-text {{item.completed ? 'done' : ''}}">{{item.content}}</text>
        <text class="delete" data-id="{{item.id}}" bindtap="deleteTodo">删除</text>
      </view>

      <view class="inline-form">
        <input class="input" value="{{newTodo}}" placeholder="新增待办项" bindinput="onNewTodoInput" />
        <button class="mini-button" bindtap="addTodo">添加</button>
      </view>
    </view>

    <view class="section panel">
      <view class="section-head">
        <text class="label">进度记录</text>
        <text class="muted">{{task.progressRecords.length}} 条</text>
      </view>
      <textarea class="textarea" value="{{progressDraft}}" placeholder="记录今天推进了什么" bindinput="onProgressInput" />
      <button class="secondary-button" loading="{{saving}}" bindtap="addProgress">添加记录</button>

      <view wx:if="{{task.progressRecords.length === 0}}" class="muted timeline-empty">暂无进度记录</view>
      <view wx:for="{{task.progressRecords}}" wx:key="id" class="timeline-item">
        <text class="timeline-time">{{item.createdText}}</text>
        <text class="timeline-content">{{item.content}}</text>
      </view>
    </view>
  </block>
</view>
