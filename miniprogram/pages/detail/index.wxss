.detail-title {
  font-size: 44rpx;
}

.title-row {
  align-items: flex-start;
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
}

.priority-label {
  background: #17171c;
  border-radius: 10rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  padding: 10rpx 16rpx;
}

.section {
  margin-top: 24rpx;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.label {
  color: #212121;
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.spaced {
  margin-top: 28rpx;
}

.secondary-button {
  background: #ffffff;
  border: 1rpx solid #17171c;
  color: #212121;
  margin-top: 18rpx;
  min-height: 82rpx;
}

.picker-row {
  display: grid;
  gap: 18rpx;
  grid-template-columns: 1fr 1fr;
}

.picker-box {
  background: #ffffff;
  border: 1rpx solid #d9d9dd;
  border-radius: 12rpx;
  color: #212121;
  font-size: 28rpx;
  padding: 22rpx;
}

.todo-row {
  align-items: center;
  border-bottom: 1rpx solid #e5e7eb;
  display: flex;
  gap: 18rpx;
  min-height: 82rpx;
}

.check {
  align-items: center;
  background: #f2f2f2;
  border-radius: 12rpx;
  color: #ffffff;
  display: flex;
  height: 48rpx;
  justify-content: center;
  width: 48rpx;
}

.check.checked {
  background: #003c33;
}

.todo-text {
  flex: 1;
  font-size: 28rpx;
}

.todo-text.done {
  color: #93939f;
  text-decoration: line-through;
}

.delete {
  color: #b30000;
  font-size: 24rpx;
}

.inline-form {
  align-items: center;
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 130rpx;
  margin-top: 20rpx;
}

.mini-button {
  background: #17171c;
  color: #ffffff;
  font-size: 26rpx;
  min-height: 78rpx;
}

.timeline-empty {
  margin-top: 20rpx;
}

.timeline-item {
  border-left: 4rpx solid #003c33;
  display: grid;
  gap: 8rpx;
  margin-top: 24rpx;
  padding-left: 20rpx;
}

.timeline-time {
  color: #75758a;
  font-size: 24rpx;
}

.timeline-content {
  color: #212121;
  font-size: 28rpx;
  line-height: 1.5;
}
