<view class="page tasks-page">
  <view class="hero">
    <view class="hero-title">放弃挣扎吧ADHD</view>
    <view class="hero-subtitle">不上班就会没饭吃，这就是打工人的宿命</view>
  </view>

  <button class="primary-button" bindtap="goCreate">新建任务</button>

  <view wx:if="{{loading}}" class="panel muted">加载中...</view>
  <view wx:elif="{{groups.length === 0}}" class="panel muted">还没有任务</view>

  <block wx:else>
    <view wx:for="{{groups}}" wx:key="status" class="folder">
      <view class="folder-head">
        <text>{{item.status}}</text>
        <text>{{item.tasks.length}}</text>
      </view>

      <view wx:if="{{item.tasks.length === 0}}" class="folder-empty">暂无任务</view>

      <view
        wx:for="{{item.tasks}}"
        wx:key="id"
        wx:for-item="task"
        class="task-card"
        data-id="{{task.id}}"
        bindtap="goDetail"
      >
        <view class="card-top">
          <view class="status-dot status-{{task.status}}"></view>
          <view class="card-title">{{task.goal}}</view>
        </view>
        <view class="card-meta">
          <text class="priority priority-{{task.priority}}">{{task.priority}}</text>
          <text>待办 {{task.todoCompleted}}/{{task.todoTotal}}</text>
        </view>
        <view class="latest">{{task.latestProgress || "暂无进度记录"}}</view>
        <view class="deadline-row">
          <text>DDL {{task.deadlineText}}</text>
          <text>{{task.timeLabel}}</text>
        </view>
        <view class="progress-track">
          <view class="progress-bar tone-{{task.tone}}" style="width: {{task.percent}}%;"></view>
        </view>
      </view>
    </view>
  </block>
</view>
