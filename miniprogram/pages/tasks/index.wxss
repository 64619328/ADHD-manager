.hero {
  margin-bottom: 10rpx;
}

.folder {
  margin-top: 30rpx;
}

.folder-head {
  align-items: center;
  border-bottom: 1rpx solid #d9d9dd;
  color: #212121;
  display: flex;
  font-size: 28rpx;
  justify-content: space-between;
  padding: 0 4rpx 16rpx;
}

.folder-empty {
  color: #75758a;
  font-size: 26rpx;
  padding: 20rpx 4rpx 6rpx;
}

.task-card {
  background: #ffffff;
  border: 1rpx solid #f2f2f2;
  border-radius: 16rpx;
  margin-top: 18rpx;
  padding: 28rpx;
}

.card-top {
  align-items: center;
  display: flex;
  gap: 18rpx;
}

.status-dot {
  border-radius: 999rpx;
  height: 14rpx;
  width: 14rpx;
}

.status-未开始 {
  background: #75758a;
}

.status-进行中 {
  background: #ff7759;
}

.status-已完成 {
  background: #003c33;
}

.card-title {
  color: #212121;
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.35;
}

.card-meta,
.deadline-row {
  align-items: center;
  color: #75758a;
  display: flex;
  font-size: 24rpx;
  gap: 14rpx;
  justify-content: space-between;
  margin-top: 18rpx;
}

.priority {
  background: #17171c;
  border-radius: 8rpx;
  color: #ffffff;
  font-weight: 600;
  padding: 6rpx 12rpx;
}

.priority-P2,
.priority-P3 {
  background: #1863dc;
}

.latest {
  color: #616161;
  font-size: 26rpx;
  margin-top: 18rpx;
}

.progress-track {
  background: #e5e7eb;
  border-radius: 999rpx;
  height: 14rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.progress-bar {
  background: #003c33;
  height: 100%;
}

.tone-urgent,
.tone-overdue {
  background: #ff7759;
}
